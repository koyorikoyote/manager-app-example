{
  "name": "manager-app",
  "version": "1.0.0",
  "description": "Manager application with React + Express SSR",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgMagenta.bold\" --names \"SERVER,CLIENT\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:fresh": "npm run prisma:generate:safe && npm run dev",
    "dev:server": "npm run prisma:generate:safe && cross-env TS_NODE_TRANSPILE_ONLY=1 PORT=3001 NODE_ENV=development nodemon --exec \"ts-node --transpile-only --project tsconfig.server.json src/server/index.ts\"",
    "dev:client": "cross-env NODE_ENV=development webpack serve --config webpack.dev.js --port 3000",
    "postinstall": "node scripts/post-install-setup.js",
    "prebuild": "npm run prisma:generate:safe",
    "dev:server:check": "node scripts/check-server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "webpack --config webpack.prod.js",
    "build:server": "webpack --config webpack.server.js --mode production",
    "build:server:dev": "webpack --config webpack.server.js --mode development",
    "start": "node dist/server/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:server": "jest --selectProjects server --forceExit",
    "test:client": "jest --selectProjects client",
    "test:backend": "ts-node src/server/__tests__/test-runner.ts",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate:safe": "node scripts/safe-prisma-generate.js",
    "prisma:generate:force": "rimraf node_modules/.prisma && timeout 2 && prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:safe": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:seed:safe": "prisma db seed",
    "prisma:truncate": "ts-node prisma/truncate.ts",
    "prisma:studio": "prisma studio --port 5555",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:clean": "rimraf node_modules/.prisma",
    "db:reset-and-seed": "ts-node --project tsconfig.server.json scripts/reset-and-seed.ts",
    "db:verify-seed": "ts-node --project tsconfig.server.json scripts/verify-seed.ts",
    "test:performance": "jest --selectProjects client --testPathPatterns=performance --forceExit",
    "test:performance:e2e": "node scripts/performance-test.js",
    "test:performance:full": "npm run test:performance && npm run test:performance:e2e"
  },
  "keywords": [
    "react",
    "express",
    "ssr",
    "typescript",
    "manager-app"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-table": "^8.21.3",
    "@types/multer": "^2.0.0",
    "@types/node-fetch": "^2.6.13",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.553.0",
    "multer": "^2.0.2",
    "mysql2": "^3.15.3",
    "node-fetch": "^3.3.2",
    "pdfjs-dist": "^5.4.394",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native-web": "^0.21.2",
    "react-pdf": "^10.2.0",
    "react-router-dom": "^7.9.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.server.json prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@swc/core": "^1.15.1",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "html-webpack-plugin": "^5.6.4",
    "ignore-loader": "^0.1.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "mini-css-extract-plugin": "^2.9.4",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "prisma": "^6.19.0",
    "puppeteer": "^24.29.1",
    "rimraf": "^6.1.0",
    "style-loader": "^4.0.0",
    "supertest": "^7.1.4",
    "swc-loader": "^0.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
}
